<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:label="NFC Reader Hook">
        
        <!-- Xposed/LSPosed 模块声明 -->
        <meta-data
            android:name="xposedmodule"
            android:value="true" />
        
        <meta-data
            android:name="xposeddescription"
            android:value="Hook NFC service to redirect tag discoveries to NFC Reader app" />
        
        <meta-data
            android:name="xposedminversion"
            android:value="93" />
            
        <!-- LSPosed 作用域声明 -->
        <meta-data
            android:name="lsposed-scope"
            android:resource="@array/scope" />
            
    </application>

</manifest>
